{
  // Live Server (Ritwick Dey extension) — serve the site on a fixed port.
  // Click "Go Live" in the status bar, then open http://127.0.0.1:5500
  "liveServer.settings.port": 5500,
  "liveServer.settings.root": "/",
  "liveServer.settings.CustomBrowser": "chrome",
  "liveServer.settings.NoBrowser": false,
  "liveServer.settings.donotShowInfoMsg": true,

  // Keep formatting consistent with the existing 2-space style.
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "files.eol": "\n"
}
